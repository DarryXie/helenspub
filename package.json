{
  "name": "cocktail-database",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "description": "Cocktail database monorepo for public menu, staff app, admin web, and API server.",
  "scripts": {
    "dev": "corepack pnpm -r --parallel --filter \"./apps/*\" dev",
    "build": "corepack pnpm -r build",
    "lint": "corepack pnpm -r lint",
    "test": "corepack pnpm -r test",
    "typecheck": "corepack pnpm -r typecheck",
    "db:generate": "corepack pnpm --filter api-server prisma generate",
    "db:migrate": "corepack pnpm --filter api-server prisma migrate dev",
    "db:seed": "corepack pnpm --filter api-server prisma db seed",
    "dev:api": "corepack pnpm --filter api-server start:dev",
    "dev:admin": "corepack pnpm --filter admin-web dev",
    "dev:public": "corepack pnpm --filter public-mobile dev",
    "dev:staff": "corepack pnpm --filter staff-mobile dev"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
